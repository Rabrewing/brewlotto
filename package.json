{
  "type": "module",
  "name": "brewlotto",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prepare": "husky install",
    "audit": "node brew-scan.js --summary",
    "audit:json": "node brew-scan.js --json",
    "audit:hook": "node brew-scan.js --hook",
    "scan": "node brew/tools/initFileIndex.cjs",
    "report": "node scripts/generateMergeReadinessReport.js",
    "test": "jest",
    "fetch-ca-data": "node scripts/fetchCAData.js",
    "scrape-ca-daily": "node scripts/scrapeCA_Data.js both 1000",
    "scrape-nc-games": "node scripts/scrapeNC_Pick3.js && node scripts/scrapeNC_Pick4.js && node scripts/scrapeNC_Cash5.js",
    "scrape-multi-state": "node scripts/scrapePowerball.js && node scripts/scrapeMega.js",
    "ingest-all": "node scripts/ingestionJob.js",
    "scheduler": "node scripts/ingestionScheduler.js",
    "scheduler:predict": "node scripts/predictionScheduler.js",
    "predict": "node scripts/runPrediction.js",
    "predict:all": "node -e \"import('./lib/prediction/predictionGenerator.js').then(m => m.runAllPredictions().then(console.log))\"",
    "health-check": "node scripts/ingestionHealth.js",
    "alerts": "npx tsx scripts/ingestionAlerts.ts",
    "validate": "node scripts/validateCrossSource.js"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@monaco-editor/react": "^4.7.0",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/auth-js": "^2.70.0",
    "@supabase/auth-ui-react": "^0.4.7",
    "@supabase/auth-ui-shared": "^0.1.8",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.50.0",
    "autoprefixer": "^10.4.21",
    "axios": "^1.10.0",
    "chart.js": "^4.5.0",
    "cheerio": "^1.1.0",
    "csv-parse": "^5.6.0",
    "csv-parser": "^3.2.0",
    "date-fns": "^4.1.0",
    "diff": "^8.0.2",
    "dotenv": "^16.5.0",
    "framer-motion": "^12.19.1",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.5",
    "next": "^15.3.4",
    "next-pwa": "^2.0.2",
    "node-cron": "^4.2.1",
    "openai": "^5.8.2",
    "postcss": "^8.5.6",
    "prismjs": "^1.30.0",
    "react": "^16.0.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.1.0",
    "react-hot-toast": "^2.5.2",
    "recharts": "^2.15.4",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/cli": "^4.1.10",
    "@tailwindcss/postcss": "^4.1.10",
    "@types/estree": "^1.0.8",
    "@types/jest": "^30.0.0",
    "@types/json-schema": "^7.0.15",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-loader": "^10.1.1",
    "eslint": "^9",
    "eslint-config-next": "15.3.4",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "mini-css-extract-plugin": "^2.9.2",
    "playwright": "^1.53.1",
    "tailwindcss": "^4.1.10",
    "typescript": "^5"
  },
