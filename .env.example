# BrewLotto example environment file
# Copy to `.env.local` and fill in real values locally.

# Core app
NEXT_PUBLIC_APP_URL="https://brewlotto.app"
NEXT_PUBLIC_ENVIRONMENT="development"
NEXT_PUBLIC_SITE_NAME="BrewLotto AI"
NEXT_PUBLIC_TAGLINE="Smart Picks. Sharper Odds."
NEXT_PUBLIC_DEFAULT_STRATEGY="A"
NEXT_PUBLIC_MAX_PREDICTIONS="5"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_URL=""
SUPABASE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Admin / auth
BREWCOMMAND_ADMIN_EMAILS="command@brewlotto.app,michael.brewington@gmail.com"
BREWCOMMAND_ADMIN_SECRET=""

# Monitoring
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Billing
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# AI provider
AI_PROVIDER="auto"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4-mini"
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
NIM_API_KEY=""
NIM_MODEL=""
NIM_BASE_URL=""

# Landing video
NEXT_PUBLIC_LANDING_VIDEO_MP4_URL=""
NEXT_PUBLIC_LANDING_VIDEO_WEBM_URL=""
BLOB_READ_WRITE_TOKEN=""
