{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@admin/*": [
        "admin/*"
      ],
      "@archive/*": [
        "archive/*"
      ],
      "@auth/*": [
        "auth/*"
      ],
      "@brew/*": [
        "brew/*"
      ],
      "@brew-command/*": [
        "brew-command/*"
      ],
      "@brew-university/*": [
        "brew-university/*"
      ],
      "@components/*": [
        "components/*"
      ],
      "@config/*": [
        "config/*"
      ],
      "@data/*": [
        "data/*"
      ],
      "@docs/*": [
        "docs/*"
      ],
      "@hooks/*": [
        "hooks/*"
      ],
      "@lib/*": [
        "lib/*"
      ],
      "@logs/*": [
        "logs/*"
      ],
      "@mnt/*": [
        "mnt/*"
      ],
      "@pages/*": [
        "pages/*"
      ],
      "@public/*": [
        "public/*"
      ],
      "@scripts/*": [
        "scripts/*"
      ],
      "@src/*": [
        "src/*"
      ],
      "@stores/*": [
        "stores/*"
      ],
      "@strategies/*": [
        "strategies/*"
      ],
      "@styles/*": [
        "styles/*"
      ],
      "@theme/*": [
        "theme/*"
      ],
      "@utils/*": [
        "utils/*"
      ]
    },
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "preserve",
    "incremental": true,
    "strict": true,
    "noEmit": true,
    "types": [
      "node",
      "estree",
      "json-schema",
      "jest",
      "mocha"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    ".next/types/**/*.ts",
    "scripts/BrewMergeFileScanner.cjs",
    "pages/api/generate-merge-report.js",
    "scripts/generateMergeReadinessReport.cjs"
  ],
  "exclude": [
    "node_modules"
  ]
}